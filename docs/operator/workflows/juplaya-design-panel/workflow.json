{
  "schema_version": "striatum.workflow.v1",
  "workflow_id": "juplaya-design-panel",
  "workflow_version": "2026-06-03",
  "name": "juplaya-design-panel",
  "branch": {
    "allow_dirty": false,
    "mode": "confirm",
    "suggested_name": "striatum/juplaya-design-panel"
  },
  "coordinator": {
    "role_id": "coordinator",
    "lane_id": "claude_code"
  },
  "allow_same_model_review_pairing": true,
  "lanes": {
    "codex": {
      "adapter": "process",
      "display_model": "Codex GPT-5.5 xhigh",
      "command": [
        "codex",
        "--yolo"
      ],
      "adapter_capabilities": {
        "agent_loop": true
      },
      "supervision": {
        "transport": "pty_helper",
        "compatible": true,
        "require_tmux": true
      },
      "capabilities": [
        "write",
        "review",
        "synthesis"
      ]
    },
    "claude_code": {
      "adapter": "process",
      "display_model": "Claude Opus 4.8",
      "command": [
        "claude",
        "--model",
        "claude-opus-4-8",
        "--permission-mode",
        "bypassPermissions"
      ],
      "adapter_capabilities": {
        "agent_loop": true
      },
      "supervision": {
        "transport": "pty_helper",
        "compatible": true,
        "require_tmux": true
      },
      "capabilities": [
        "write",
        "review",
        "synthesis"
      ]
    },
    "agy": {
      "adapter": "process",
      "display_model": "Gemini 3.5 Flash High",
      "command": [
        "agy",
        "--dangerously-skip-permissions"
      ],
      "adapter_capabilities": {
        "agent_loop": true
      },
      "capabilities": [
        "write",
        "review"
      ]
    }
  },
  "roles": {
    "coordinator": {
      "definition_path": "roles/coordinator.md"
    },
    "designer": {
      "definition_path": "roles/designer.md"
    },
    "synthesizer": {
      "definition_path": "roles/synthesizer.md"
    },
    "implementer": {
      "definition_path": "roles/implementer.md"
    },
    "reviewer": {
      "definition_path": "roles/reviewer.md"
    }
  },
  "context_docs": [
    {
      "path": "README.md",
      "required": false
    }
  ],
  "parallelism": {
    "mode": "declared",
    "max_active_jobs": 3,
    "require_disjoint_write_scopes": true
  },
  "jobs": [
    {
      "id": "design_codex",
      "type": "draft",
      "title": "Design (codex lane)",
      "role_id": "designer",
      "lane_id": "codex",
      "parallel_group": "design",
      "fresh_session_required": true,
      "objective": "Second full pass: read design_claude's draft, correct and extend it.",
      "task_prompt": {
        "path": "prompts/design.md"
      },
      "write_scope": {
        "mode": "repo_write",
        "repo_write": true,
        "allowed_paths": [
          "runs/juplaya-design-panel/design_codex/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "codex_design",
          "kind": "handoff",
          "path": "runs/juplaya-design-panel/design_codex/codex_design.md",
          "required": true
        }
      ]
    },
    {
      "id": "design_claude",
      "type": "draft",
      "title": "Design (claude_code lane)",
      "role_id": "designer",
      "lane_id": "claude_code",
      "parallel_group": "design",
      "fresh_session_required": true,
      "objective": "First full pass over the whole problem set.",
      "task_prompt": {
        "path": "prompts/design.md"
      },
      "write_scope": {
        "mode": "repo_write",
        "repo_write": true,
        "allowed_paths": [
          "runs/juplaya-design-panel/design_claude/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "claude_design",
          "kind": "handoff",
          "path": "runs/juplaya-design-panel/design_claude/claude_design.md",
          "required": true
        }
      ]
    },
    {
      "id": "design_gemini",
      "type": "draft",
      "title": "Design (gemini lane)",
      "role_id": "designer",
      "lane_id": "agy",
      "parallel_group": "design",
      "fresh_session_required": true,
      "objective": "Third full pass: read design_codex's draft, correct and extend it.",
      "task_prompt": {
        "path": "prompts/design.md"
      },
      "write_scope": {
        "mode": "repo_write",
        "repo_write": true,
        "allowed_paths": [
          "runs/juplaya-design-panel/design_gemini/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "gemini_design",
          "kind": "handoff",
          "path": "runs/juplaya-design-panel/design_gemini/gemini_design.md",
          "required": true
        }
      ]
    },
    {
      "id": "synth",
      "type": "synthesis",
      "title": "Synthesize designs (interrogable)",
      "role_id": "synthesizer",
      "lane_id": "claude_code",
      "fresh_session_required": true,
      "interrogable": true,
      "objective": "Reconcile the three design proposals into a single buildable synthesis. Stay live after completing so the design-review panel can interrogate your preserved reasoning.",
      "task_prompt": {
        "path": "prompts/synth.md"
      },
      "write_scope": {
        "mode": "repo_write",
        "repo_write": true,
        "allowed_paths": [
          "runs/juplaya-design-panel/synth/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "design_synthesis",
          "kind": "synthesis",
          "path": "runs/juplaya-design-panel/synth/design_synthesis.md",
          "required": true
        }
      ],
      "interrogation": {
        "interrogable": true
      }
    },
    {
      "id": "review_design_codex",
      "type": "review",
      "title": "Design review codex threat_model",
      "role_id": "reviewer",
      "lane_id": "codex",
      "parallel_group": "design_review",
      "fresh_session_required": true,
      "reviewer_context_policy": "fresh",
      "reviewer_access_scope": "document_only",
      "review_posture": "threat_model",
      "objective": "Threat-model the design synthesis and interrogate the live synthesizer session before rendering a verdict.",
      "task_prompt": {
        "path": "prompts/review_design.md"
      },
      "inputs": [
        "design_synthesis"
      ],
      "write_scope": {
        "mode": "review_only_artifact",
        "repo_write": false,
        "allowed_paths": [
          "runs/juplaya-design-panel/review_design_codex/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "design_review_codex",
          "kind": "finding",
          "path": "runs/juplaya-design-panel/review_design_codex/design_review_codex.md",
          "required": true
        }
      ]
    },
    {
      "id": "review_design_claude",
      "type": "review",
      "title": "Design review claude ergonomics_dx",
      "role_id": "reviewer",
      "lane_id": "claude_code",
      "parallel_group": "design_review",
      "fresh_session_required": true,
      "reviewer_context_policy": "fresh",
      "reviewer_access_scope": "document_only",
      "review_posture": "ergonomics_dx",
      "objective": "Review the design synthesis for ergonomics and developer experience, then interrogate the live synthesizer session before rendering a verdict.",
      "task_prompt": {
        "path": "prompts/review_design.md"
      },
      "inputs": [
        "design_synthesis"
      ],
      "write_scope": {
        "mode": "review_only_artifact",
        "repo_write": false,
        "allowed_paths": [
          "runs/juplaya-design-panel/review_design_claude/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "design_review_claude",
          "kind": "finding",
          "path": "runs/juplaya-design-panel/review_design_claude/design_review_claude.md",
          "required": true
        }
      ]
    },
    {
      "id": "review_design_gemini",
      "type": "review",
      "title": "Design review gemini devils_advocate",
      "role_id": "reviewer",
      "lane_id": "agy",
      "parallel_group": "design_review",
      "fresh_session_required": true,
      "reviewer_context_policy": "fresh",
      "reviewer_access_scope": "document_only",
      "review_posture": "devils_advocate",
      "objective": "Adversarially probe the design synthesis, then interrogate the live synthesizer session before rendering a verdict.",
      "task_prompt": {
        "path": "prompts/review_design.md"
      },
      "inputs": [
        "design_synthesis"
      ],
      "write_scope": {
        "mode": "review_only_artifact",
        "repo_write": false,
        "allowed_paths": [
          "runs/juplaya-design-panel/review_design_gemini/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "design_review_gemini",
          "kind": "finding",
          "path": "runs/juplaya-design-panel/review_design_gemini/design_review_gemini.md",
          "required": true
        }
      ]
    },
    {
      "id": "implement",
      "type": "build",
      "title": "Implement synthesized design (interrogable)",
      "role_id": "implementer",
      "lane_id": "claude_code",
      "interrogable": true,
      "required_review_postures": [
        "threat_model",
        "ergonomics_dx",
        "devils_advocate"
      ],
      "objective": "Implement the synthesized design. Land only the changes the synthesis and the design panel converge on, write a handoff, and stay live so the build-review panel can interrogate your preserved reasoning.",
      "task_prompt": {
        "path": "prompts/implement.md"
      },
      "write_scope": {
        "mode": "repo_write",
        "repo_write": true,
        "allowed_paths": [
          "runs/juplaya-design-panel/",
          "docs/"
        ],
        "forbidden_paths": [
          ".striatum/",
          "docs/operator/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "build_handoff",
          "kind": "handoff",
          "path": "runs/juplaya-design-panel/implement/build_handoff.md",
          "required": true
        }
      ],
      "interrogation": {
        "interrogable": true
      }
    },
    {
      "id": "review_build_codex",
      "type": "review",
      "title": "Build review codex threat_model",
      "role_id": "reviewer",
      "lane_id": "codex",
      "parallel_group": "build_review",
      "fresh_session_required": true,
      "reviewer_context_policy": "fresh",
      "reviewer_access_scope": "document_only",
      "review_posture": "threat_model",
      "objective": "Threat-model the implementation and interrogate the live implementer session before rendering a verdict.",
      "task_prompt": {
        "path": "prompts/review_build.md"
      },
      "inputs": [
        "build_handoff",
        "design_synthesis"
      ],
      "write_scope": {
        "mode": "review_only_artifact",
        "repo_write": false,
        "allowed_paths": [
          "runs/juplaya-design-panel/review_build_codex/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "build_review_codex",
          "kind": "finding",
          "path": "runs/juplaya-design-panel/review_build_codex/build_review_codex.md",
          "required": true
        }
      ]
    },
    {
      "id": "review_build_claude",
      "type": "review",
      "title": "Build review claude ergonomics_dx",
      "role_id": "reviewer",
      "lane_id": "claude_code",
      "parallel_group": "build_review",
      "fresh_session_required": true,
      "reviewer_context_policy": "fresh",
      "reviewer_access_scope": "document_only",
      "review_posture": "ergonomics_dx",
      "objective": "Review the implementation for operator and developer ergonomics, then interrogate the live implementer session before rendering a verdict.",
      "task_prompt": {
        "path": "prompts/review_build.md"
      },
      "inputs": [
        "build_handoff",
        "design_synthesis"
      ],
      "write_scope": {
        "mode": "review_only_artifact",
        "repo_write": false,
        "allowed_paths": [
          "runs/juplaya-design-panel/review_build_claude/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "build_review_claude",
          "kind": "finding",
          "path": "runs/juplaya-design-panel/review_build_claude/build_review_claude.md",
          "required": true
        }
      ]
    },
    {
      "id": "review_build_gemini",
      "type": "review",
      "title": "Build review gemini devils_advocate",
      "role_id": "reviewer",
      "lane_id": "agy",
      "parallel_group": "build_review",
      "fresh_session_required": true,
      "reviewer_context_policy": "fresh",
      "reviewer_access_scope": "document_only",
      "review_posture": "devils_advocate",
      "objective": "Adversarially probe the implementation, then interrogate the live implementer session before rendering a verdict.",
      "task_prompt": {
        "path": "prompts/review_build.md"
      },
      "inputs": [
        "build_handoff",
        "design_synthesis"
      ],
      "write_scope": {
        "mode": "review_only_artifact",
        "repo_write": false,
        "allowed_paths": [
          "runs/juplaya-design-panel/review_build_gemini/"
        ],
        "forbidden_paths": [
          ".striatum/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "build_review_gemini",
          "kind": "finding",
          "path": "runs/juplaya-design-panel/review_build_gemini/build_review_gemini.md",
          "required": true
        }
      ]
    }
  ],
  "edges": [
    {
      "from": "synth",
      "to": "review_design_codex",
      "on": "completed"
    },
    {
      "from": "synth",
      "to": "review_design_claude",
      "on": "completed"
    },
    {
      "from": "synth",
      "to": "review_design_gemini",
      "on": "completed"
    },
    {
      "from": "review_design_codex",
      "to": "implement",
      "on": "completed"
    },
    {
      "from": "review_design_claude",
      "to": "implement",
      "on": "completed"
    },
    {
      "from": "review_design_gemini",
      "to": "implement",
      "on": "completed"
    },
    {
      "from": "implement",
      "to": "review_build_codex",
      "on": "completed"
    },
    {
      "from": "implement",
      "to": "review_build_claude",
      "on": "completed"
    },
    {
      "from": "implement",
      "to": "review_build_gemini",
      "on": "completed"
    },
    {
      "from": "design_claude",
      "on": "completed",
      "to": "design_codex"
    },
    {
      "from": "design_codex",
      "on": "completed",
      "to": "design_gemini"
    },
    {
      "from": "design_gemini",
      "on": "completed",
      "to": "synth"
    }
  ],
  "cycles": [
    {
      "from": "review_design_codex",
      "to": "synth",
      "on_verdict": "needs_revision",
      "max_iterations": 2,
      "allow_same_lane": true
    },
    {
      "from": "review_design_claude",
      "to": "synth",
      "on_verdict": "needs_revision",
      "max_iterations": 2,
      "allow_same_lane": true
    },
    {
      "from": "review_design_gemini",
      "to": "synth",
      "on_verdict": "needs_revision",
      "max_iterations": 2,
      "allow_same_lane": true
    },
    {
      "from": "review_build_codex",
      "to": "implement",
      "on_verdict": "needs_revision",
      "max_iterations": 2,
      "allow_same_lane": true
    },
    {
      "from": "review_build_claude",
      "to": "implement",
      "on_verdict": "needs_revision",
      "max_iterations": 2,
      "allow_same_lane": true
    },
    {
      "from": "review_build_gemini",
      "to": "implement",
      "on_verdict": "needs_revision",
      "max_iterations": 2,
      "allow_same_lane": true
    }
  ]
}
